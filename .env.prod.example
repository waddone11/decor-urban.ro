BING_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=

# Tracking - se incarca dupa consent unde este cazul
GTM_CONTAINER_ID=
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
TIKTOK_PIXEL_ID=

# Feeds
META_FEED_TOKEN=

# /commands - helper permanent, 404 daca SECRET este gol sau gresit
SECRET=
COMMAND_RATE_LIMIT=30

# Gemini - pentru comenzile de enrich; nu completa daca nu folosesti AI enrichment
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash

# Seed admin - doar pentru migrate:fresh --seed controlat
SEED_ADMIN_1_NAME=Admin
SEED_ADMIN_1_EMAIL=
SEED_ADMIN_1_PASSWORD=
SEED_ADMIN_2_NAME=Admin
SEED_ADMIN_2_EMAIL=
SEED_ADMIN_2_PASSWORD=
