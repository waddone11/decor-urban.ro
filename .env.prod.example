APP_NAME="Decor Urban"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://decor-urban.ro
APP_LOCALE=ro
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ro_RO
APP_PREVIOUS_KEYS=

# Maintenance mode
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Auth
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

# Database - completeaza din cPanel/MySQL
DB_CONNECTION=mysql
DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true
DB_SSLMODE=prefer
MYSQL_ATTR_SSL_CA=

# Cache
CACHE_STORE=database
CACHE_PREFIX=
CACHE_STORAGE_DISK=
CACHE_STORAGE_PATH=framework/cache/data
DB_CACHE_CONNECTION=
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=
DB_CACHE_LOCK_TABLE=
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=
DYNAMODB_CACHE_TABLE=cache
DYNAMODB_ENDPOINT=

# Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_CONNECTION=
SESSION_STORE=
SESSION_TABLE=sessions
SESSION_COOKIE=
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
SESSION_EXPIRE_ON_CLOSE=false

# Queue
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
BEANSTALKD_QUEUE_HOST=localhost
BEANSTALKD_QUEUE=default
BEANSTALKD_QUEUE_RETRY_AFTER=90
SQS_PREFIX=
SQS_QUEUE=default
SQS_SUFFIX=

# Redis - completeaza doar daca folosesti Redis
REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_CLUSTER=redis
REDIS_PREFIX=
REDIS_PERSISTENT=false
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# Filesystem / S3 - local/public pe shared hosting; S3 doar daca este folosit
# (upload-urile Filament folosesc explicit disk('public'), nu au nevoie de env separat)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mail - SMTP real; CONTACT_EMAIL primeste formularele/comenzile
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_URL=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAIL_LOG_CHANNEL=
MAIL_FROM_ADDRESS="contact@decor-urban.ro"
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_API_KEY=
RESEND_API_KEY=

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_DAILY_DAYS=14
COMMAND_LOG_DAYS=90
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="${APP_NAME}"
LOG_SLACK_EMOJI=:boom:
LOG_PAPERTRAIL_HANDLER=Monolog\Handler\SyslogUdpHandler
LOG_STDERR_FORMATTER=
LOG_SYSLOG_FACILITY=8
PAPERTRAIL_URL=
PAPERTRAIL_PORT=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

