APP_NAME="Decor Urban"
APP_ENV=production
APP_KEY=                      # copiază APP_KEY din .env local (NU genera altul)
APP_DEBUG=false
APP_URL=https://decor-urban.ro
LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1             # de obicei localhost pe shared
DB_PORT=3306
DB_DATABASE=___completezi___
DB_USERNAME=___completezi___
DB_PASSWORD=___completezi___

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=sync         # fără worker pe shared

FILAMENT_FILESYSTEM_DISK=public
FILESYSTEM_DISK=local

# Mail (SMTP real — comenzile nu pleacă fără el)
MAIL_MAILER=smtp
MAIL_HOST=___completezi___
MAIL_PORT=587
MAIL_USERNAME=___completezi___
MAIL_PASSWORD=___completezi___
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@decor-urban.ro"
MAIL_FROM_NAME="${APP_NAME}"

# Contact (afișate pe site) — valori reale
CONTACT_PHONE="+40 758 522 227"
CONTACT_WHATSAPP="40758522227"          # doar cifre, pt wa.me/
CONTACT_EMAIL="contact@decor-urban.ro"  # aici ajung comenzile
CONTACT_IS_PLACEHOLDER=false

# Firmă (reale, din certificat)
COMPANY_LEGAL_NAME="MOBILIER-STRADAL RO 2026 S.R.L."
COMPANY_BRAND="Decor Urban"
COMPANY_CUI="54295156"
COMPANY_REG_COM="J2026018529009"
COMPANY_EUID="ROONRC.J2026018529009"
COMPANY_ADDRESS="Str. Băltați nr. 149, Sat Băltați, Oraș Scornicești, Jud. Olt"
COMPANY_CAEN="4619"
COMPANY_FOUNDED="2026-03-19"
COMPANY_IS_PLACEHOLDER=false
# opționale — completezi când le confirmi (altfel rămân ascunse):
COMPANY_CPV=
COMPANY_SEAP_PRESENT=
COMPANY_PROJECTS=
COMPANY_REFERENCES=
COMPANY_STANDARDS=

# Command runner (/commands) — o singură cheie, lungă/random, NU o comite
SECRET=___pune_secret_lung_random___
