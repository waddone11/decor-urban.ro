APP_NAME="Decor Urban"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ro
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ro_RO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=decor_urban
DB_USERNAME=decor
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — LOCAL: Mailpit (mai jos). PROD: înlocuiește cu un SMTP real (al tău sau un
# serviciu tranzacțional). Fără SMTP real, emailurile de comandă NU pleacă (vezi README).
# Adresa care primește comenzile = CONTACT_EMAIL (config/contact.php), nu MAIL_FROM_ADDRESS.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@decor-urban.ro"
MAIL_FROM_NAME="${APP_NAME}"
# PROD (exemplu):
# MAIL_HOST=smtp.exemplu.ro
# MAIL_PORT=587
# MAIL_USERNAME=comenzi@decor-urban.ro
# MAIL_PASSWORD=parola-smtp
# MAIL_SCHEME=tls

VITE_APP_NAME="${APP_NAME}"

# /commands — helper artisan din URL (deploy fără SSH). O singură cheie, lungă, random
# (ex. php artisan str:random 48). NU o comite. Gol → /commands întoarce 404.
